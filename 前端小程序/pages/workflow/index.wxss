.container {
  background: #f3f5f8;
  min-height: 100vh;
  padding-bottom: calc(88rpx + env(safe-area-inset-bottom) + 20rpx);
}

.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
  padding: 34rpx 32rpx 28rpx;
  background: #14213d;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.role-bar {
  background: #243655;
  padding: 18rpx 32rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
}

.role-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}

/* Tab 切换 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #e7ecf2;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  min-width: 0;
  padding: 24rpx 4rpx;
  font-size: 27rpx;
  color: #666;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  white-space: nowrap;
}

.tab-active {
  color: #14213d;
  font-weight: 800;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #fca311;
  border-radius: 2rpx;
}

.tab-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 2rpx 12rpx;
  background: #d92d20;
  color: #fff;
  font-size: 22rpx;
  border-radius: 20rpx;
  min-width: 32rpx;
  flex-shrink: 0;
}

/* 列表 */
.list-section {
  padding: 20rpx 24rpx 28rpx;
}

.workflow-card {
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  padding: 26rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 33, 61, 0.05);
  border: 1rpx solid #e7ecf2;
}

.workflow-card.completed {
  opacity: 0.7;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
  gap: 18rpx;
}

.waybill-info {
  flex: 1;
  min-width: 0;
}

.waybill-no {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #14213d;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.factory-name {
  display: block;
  font-size: 26rpx;
  color: #667085;
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-badge.created {
  background: #edf2f7;
  color: #14213d;
}

.status-badge.factory_confirmed {
  background: #fff2d9;
  color: #8a4b10;
}

.status-badge.measured_priced {
  background: #eef4ff;
  color: #3538cd;
}

.status-badge.admin_confirmed {
  background: #e6f6f3;
  color: #0f766e;
}

.status-badge.warehouse_delivered {
  background: #ecfdff;
  color: #0e7090;
}

.status-badge.completed {
  background: #F5F5F5;
  color: #999;
}

.status-badge.mainline {
  background: #fff2d9;
  color: #8a4b10;
}

.status-badge.billed {
  background: #E8F5E9;
  color: #388E3C;
}

.card-body {
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #edf1f6;
  margin-bottom: 16rpx;
}

.cargo-info {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #344054;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
  gap: 4rpx 0;
}

.cargo-divider {
  margin: 0 12rpx;
  color: #ddd;
}

.route-info {
  font-size: 24rpx;
  color: #667085;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.payment-type {
  margin-top: 8rpx;
}

.pay-tag {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.pay-tag.monthly {
  background: #edf2f7;
  color: #14213d;
}

.pay-tag.spot {
  background: #fff2d9;
  color: #8a4b10;
}

.card-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 180rpx;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 68rpx;
}

.step-num {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  font-size: 22rpx;
  font-weight: 600;
  background: rgba(255,255,255,0.3);
}

.btn-secondary .step-num {
  background: #ddd;
  color: #666;
}

.btn-primary .step-num {
  background: rgba(255,255,255,0.3);
  color: #fff;
}

.action-arrow {
  font-size: 32rpx;
  color: #ccc;
  font-weight: 600;
}

.btn-primary {
  background: #fca311;
  color: #14213d;
  font-weight: 800;
}

.btn-warn {
  background: #14213d;
  color: #fff;
}

.btn-secondary {
  background: #edf2f7;
  color: #344054;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  background: #fff;
  border-radius: 10rpx;
  border: 1rpx solid #e7ecf2;
  box-shadow: 0 10rpx 26rpx rgba(20, 33, 61, 0.05);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}

/* 日期分组 */
.date-group {
  padding: 20rpx 8rpx 12rpx;
}

.date-group-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
}

/* 建单时间 */
.create-time {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.time-label {
  font-size: 22rpx;
  color: #999;
}

.time-value {
  font-size: 24rpx;
  color: #666;
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */

/* === No Emoji UI Icons === */
.empty-icon,
.ai-icon,
.upload-icon,
.add-icon,
.ai-result-icon,
.status-icon {
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  font-size: 0 !important;
  line-height: 1;
  color: transparent !important;
  background: transparent;
}

.empty-icon,
.empty-line-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #fbfaf7;
}

.empty-icon::before,
.empty-line-icon::before {
  content: '';
  position: absolute;
  left: 22rpx;
  top: 28rpx;
  width: 50rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #14213d;
  box-shadow: 0 18rpx 0 #ff6b00;
}

.empty-icon::after,
.empty-line-icon::after {
  content: '';
  position: absolute;
  left: 22rpx;
  bottom: 20rpx;
  width: 34rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #d8dee8;
}

.ai-icon,
.upload-icon,
.add-icon,
.ai-line-icon,
.upload-line-icon,
.add-line-icon {
  width: 92rpx;
  height: 72rpx;
  margin-bottom: 18rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 16rpx;
  background: #fff7ef;
}

.ai-icon::before,
.upload-icon::before,
.add-icon::before,
.ai-line-icon::before,
.upload-line-icon::before,
.add-line-icon::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 50%;
  background: #fffefa;
}

.ai-icon::after,
.upload-icon::after,
.add-icon::after,
.ai-line-icon::after,
.upload-line-icon::after,
.add-line-icon::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: -12rpx;
  width: 30rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #ff6b00;
}

.ai-result-icon {
  width: 58rpx;
  height: 58rpx;
  margin: 0 20rpx 0 0;
  border-radius: 50%;
  color: #fff !important;
  text-align: center;
  line-height: 58rpx;
  font-size: 30rpx !important;
  font-weight: 900;
  background: #0f766e;
}

.ai-result-icon.warning {
  background: #d97706;
}

.status-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(255,255,255,0.34);
  background: rgba(255,255,255,0.14);
  margin: 0 24rpx 0 0;
}

.status-icon::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 24rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #fff;
  box-shadow: 0 16rpx 0 #fca311;
}

.warning-text::before,
.payment-tip text::before {
  content: '!';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #fff1dc;
  color: #9a4b10;
  font-size: 20rpx;
  font-weight: 900;
}

.wechat-icon {
  display: none !important;
}

/* === End No Emoji UI Icons === */
