.container {
  padding: 64rpx 32rpx;
  background: #f7f8fa;
  min-height: 100vh;
}

.role-header {
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.role-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.22;
}

.role-subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-top: 12rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.role-card {
  display: flex;
  align-items: center;
  padding: 34rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 18rpx rgba(31, 41, 55, 0.05);
  border: 1rpx solid #eef1f5;
  transition: transform 0.16s ease, border-color 0.16s ease;
}

.role-card:active {
  transform: scale(0.985);
  border-color: #ffd0a8;
}

.role-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff3e8;
  font-size: 40rpx;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.role-info {
  flex: 1;
}

.role-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.35;
}

.role-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.role-arrow {
  font-size: 40rpx;
  color: #b8c0cc;
  margin-left: 16rpx;
}

/* 登录表单 */
.login-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 30rpx 40rpx;
  margin-top: 20rpx;
  box-shadow: 0 6rpx 22rpx rgba(31, 41, 55, 0.07);
  border: 1rpx solid #eef1f5;
}

.login-back {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 36rpx;
}

.back-arrow {
  font-size: 40rpx;
  margin-right: 8rpx;
}

.login-title {
  margin-bottom: 42rpx;
}

.login-title text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.login-subtitle {
  font-size: 28rpx !important;
  font-weight: 400 !important;
  color: #999 !important;
  margin-top: 12rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.login-input {
  width: 100%;
  height: 88rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  border: 1rpx solid #e6ebf1;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  background: #FF6B00;
  color: #fff;
  border-radius: 14rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 44rpx;
  box-shadow: 0 8rpx 18rpx rgba(255, 107, 0, 0.22);
}

.btn-wechat-login {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  color: #fff;
  border-radius: 14rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 24rpx;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(7, 193, 96, 0.18);
}

.btn-wechat-login::after {
  border: none;
}

.wechat-icon {
  font-size: 36rpx;
}

.login-hint {
  text-align: center;
  margin-top: 24rpx;
}

.login-hint text {
  font-size: 24rpx;
  color: #bbb;
}

.manual-login-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #FF6B00;
}

.btn-disabled {
  opacity: 0.6;
}
