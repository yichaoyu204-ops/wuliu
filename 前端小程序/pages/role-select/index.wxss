.container {
  position: relative;
  overflow: hidden;
  padding: 76rpx 32rpx;
  background: linear-gradient(180deg, #14213d 0%, #243655 34%, #f3f5f8 34%);
  min-height: 100vh;
}

.role-header {
  margin-bottom: 48rpx;
  padding: 0 8rpx;
}

.role-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.22;
}

.role-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.64);
  margin-top: 12rpx;
}

.role-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.role-card {
  display: flex;
  align-items: center;
  padding: 34rpx 30rpx;
  background: #fff;
  border-radius: 10rpx;
  box-shadow: 0 14rpx 32rpx rgba(20, 33, 61, 0.08);
  border: 1rpx solid #e7ecf2;
  transition: transform 0.16s ease, border-color 0.16s ease;
}

.role-card:active {
  transform: scale(0.985);
  border-color: #ffd0a8;
}

.role-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #edf2f7;
  color: #14213d;
  font-size: 30rpx;
  font-weight: 900;
  margin-right: 22rpx;
  flex-shrink: 0;
}

.role-salesman .role-icon {
  background: #fff2d9;
  color: #8a4b10;
}

.role-warehouse .role-icon {
  background: #e6f6f3;
  color: #0f766e;
}

.role-admin .role-icon {
  background: #edf2f7;
  color: #14213d;
}

.role-info {
  flex: 1;
}

.role-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #14213d;
  line-height: 1.35;
}

.role-desc {
  display: block;
  font-size: 24rpx;
  color: #667085;
  margin-top: 8rpx;
}

.role-arrow {
  font-size: 40rpx;
  color: #b8c0cc;
  margin-left: 16rpx;
}

/* 登录表单 */
.login-form {
  background: #fff;
  border-radius: 10rpx;
  padding: 36rpx 30rpx 40rpx;
  margin-top: 20rpx;
  box-shadow: 0 14rpx 32rpx rgba(20, 33, 61, 0.08);
  border: 1rpx solid #e7ecf2;
}

.login-back {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 36rpx;
}

.back-arrow {
  font-size: 40rpx;
  margin-right: 8rpx;
}

.login-title {
  margin-bottom: 42rpx;
}

.login-title text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #14213d;
}

.login-subtitle {
  font-size: 28rpx !important;
  font-weight: 400 !important;
  color: #999 !important;
  margin-top: 12rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.input-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.login-input {
  width: 100%;
  height: 88rpx;
  background: #f8fafc;
  border-radius: 8rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #1a1a1a;
  box-sizing: border-box;
  border: 1rpx solid #e6ebf1;
}

.btn-login {
  width: 100%;
  height: 96rpx;
  background: #fca311;
  color: #14213d;
  border-radius: 8rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 44rpx;
  box-shadow: 0 10rpx 22rpx rgba(252, 163, 17, 0.22);
}

.btn-wechat-login {
  width: 100%;
  height: 96rpx;
  background: #07C160;
  color: #fff;
  border-radius: 8rpx;
  text-align: center;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 24rpx;
  border: none;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(7, 193, 96, 0.18);
}

.btn-wechat-login::after {
  border: none;
}

.wechat-icon {
  font-size: 36rpx;
}

.login-hint {
  text-align: center;
  margin-top: 24rpx;
}

.login-hint text {
  font-size: 24rpx;
  color: #bbb;
}

.manual-login-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #8a4b10;
}

.btn-disabled {
  opacity: 0.6;
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */

/* === Role Select Page Fix === */
.container {
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  padding: 0 32rpx 64rpx;
  background: #f8f7f4;
}

.container::before {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 360rpx;
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  border-radius: 0 0 36rpx 36rpx;
}

.role-header {
  position: relative;
  z-index: 1;
  margin: 0 -32rpx 30rpx;
  padding: 64rpx 64rpx 56rpx;
}

.role-title {
  display: block;
  max-width: 620rpx;
  color: #fff;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1.22;
  text-shadow: 0 4rpx 12rpx rgba(120, 48, 0, 0.18);
}

.role-subtitle {
  display: block;
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.86);
  font-size: 28rpx;
  line-height: 1.45;
}

.role-list {
  position: relative;
  z-index: 2;
  gap: 20rpx;
}

.role-card {
  background: #fffefa;
  border-color: #eadfd2;
  border-radius: 18rpx;
  padding: 34rpx 30rpx;
  box-shadow: 0 14rpx 34rpx rgba(20, 33, 61, 0.08);
}

.role-icon {
  border-radius: 16rpx;
}

.role-arrow {
  color: #c7cdd8;
  font-size: 44rpx;
}

.login-form {
  position: relative;
  z-index: 2;
}

/* === End Role Select Page Fix === */

/* === Premium Role Landing Refinement === */
.container {
  padding: 28rpx 32rpx 72rpx;
  background:
    linear-gradient(180deg, rgba(255, 107, 0, 0.08) 0%, rgba(255, 107, 0, 0) 300rpx),
    #f8f7f4;
}

.container::before {
  display: none;
}

.role-header {
  position: relative;
  margin: 22rpx 0 28rpx;
  padding: 32rpx 34rpx 32rpx 42rpx;
  background: #fffefa;
  border: 1rpx solid #eadfd2;
  border-radius: 18rpx;
  box-shadow: 0 12rpx 30rpx rgba(20, 33, 61, 0.065);
}

.role-header::before {
  content: '';
  position: absolute;
  left: 24rpx;
  top: 34rpx;
  width: 6rpx;
  height: 96rpx;
  border-radius: 999rpx;
  background: #ff6b00;
}

.role-header::after {
  content: '';
  display: block;
  width: 72rpx;
  height: 6rpx;
  margin-top: 24rpx;
  border-radius: 999rpx;
  background: #ffe1c9;
}

.role-eyebrow {
  display: block;
  margin-bottom: 10rpx;
  color: #9a4b10;
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.role-title {
  max-width: none;
  color: #14213d;
  font-size: 40rpx;
  line-height: 1.25;
  text-shadow: none;
}

.role-subtitle {
  margin-top: 10rpx;
  color: #697386;
  font-size: 26rpx;
}

.role-card {
  padding: 34rpx 32rpx;
  border-radius: 18rpx;
}

.role-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
}

/* === End Premium Role Landing Refinement === */

/* === No Emoji UI Icons === */
.empty-icon,
.ai-icon,
.upload-icon,
.add-icon,
.ai-result-icon,
.status-icon {
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  font-size: 0 !important;
  line-height: 1;
  color: transparent !important;
  background: transparent;
}

.empty-icon,
.empty-line-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #fbfaf7;
}

.empty-icon::before,
.empty-line-icon::before {
  content: '';
  position: absolute;
  left: 22rpx;
  top: 28rpx;
  width: 50rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #14213d;
  box-shadow: 0 18rpx 0 #ff6b00;
}

.empty-icon::after,
.empty-line-icon::after {
  content: '';
  position: absolute;
  left: 22rpx;
  bottom: 20rpx;
  width: 34rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #d8dee8;
}

.ai-icon,
.upload-icon,
.add-icon,
.ai-line-icon,
.upload-line-icon,
.add-line-icon {
  width: 92rpx;
  height: 72rpx;
  margin-bottom: 18rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 16rpx;
  background: #fff7ef;
}

.ai-icon::before,
.upload-icon::before,
.add-icon::before,
.ai-line-icon::before,
.upload-line-icon::before,
.add-line-icon::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 50%;
  background: #fffefa;
}

.ai-icon::after,
.upload-icon::after,
.add-icon::after,
.ai-line-icon::after,
.upload-line-icon::after,
.add-line-icon::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: -12rpx;
  width: 30rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #ff6b00;
}

.ai-result-icon {
  width: 58rpx;
  height: 58rpx;
  margin: 0 20rpx 0 0;
  border-radius: 50%;
  color: #fff !important;
  text-align: center;
  line-height: 58rpx;
  font-size: 30rpx !important;
  font-weight: 900;
  background: #0f766e;
}

.ai-result-icon.warning {
  background: #d97706;
}

.status-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(255,255,255,0.34);
  background: rgba(255,255,255,0.14);
  margin: 0 24rpx 0 0;
}

.status-icon::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 24rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #fff;
  box-shadow: 0 16rpx 0 #fca311;
}

.warning-text::before,
.payment-tip text::before {
  content: '!';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #fff1dc;
  color: #9a4b10;
  font-size: 20rpx;
  font-weight: 900;
}

.wechat-icon {
  display: none !important;
}

/* === End No Emoji UI Icons === */
