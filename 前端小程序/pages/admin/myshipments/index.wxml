<view class="container">
  <!-- 顶部提示 -->
  <view class="tip-bar">
    <text class="tip-text">显示您创建的所有运单，新录入的订单自动出现在此处</text>
  </view>

  <!-- 运单列表 -->
  <view class="shipment-list" wx:if="{{!loading}}">
    <view
      wx:for="{{shipments}}"
      wx:key="_id"
      class="shipment-card"
      bindtap="goToDetail"
      data-id="{{item._id}}"
    >
      <view class="card-header">
        <text class="shipment-id">{{item._id}}</text>
        <view class="status-tag {{item.status}}">{{item.currentNodeName || '运输中'}}</view>
      </view>

      <view class="card-body">
        <text class="factory-name">{{item.creatorName || '——'}}</text>
        <text class="cargo-info">{{item.cargoInfo.pieces || '-'}} {{item.cargoInfo.piecesUnit || '件'}} / {{item.cargoInfo.grossWeight || '-'}} {{item.cargoInfo.weightUnit || 'KGS'}} / {{item.cargoInfo.volume || '-'}} {{item.cargoInfo.volumeUnit || 'CBM'}}</text>
      </view>

      <view class="card-footer">
        <text class="create-time">{{item.createdAt}}</text>
        <view class="footer-right">
          <text class="amount" wx:if="{{item.totalAmount > 0}}">¥{{item.totalAmount}}</text>
          <text class="amount-unquoted" wx:else>未报价</text>
          <text class="delete-btn" wx:if="{{isAdmin}}" catchtap="deleteShipment" data-id="{{item._id}}">删除</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{shipments.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无运单</text>
      <text class="empty-hint">在"建单"页面录入订单后会自动显示</text>
      <view class="empty-btn" bindtap="goToCreate">去建单</view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>
</view>
