.container {
  background: #f5f7fa;
  min-height: 100vh;
}

/* 顶部提示 */
.tip-bar {
  background: #fff7e6;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #ffe7ba;
}

.tip-text {
  font-size: 24rpx;
  color: #fa8c16;
}

/* 运单列表 */
.shipment-list {
  padding: 20rpx 24rpx;
}

.shipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.shipment-id {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
  font-family: monospace;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-tag.active {
  color: #FF6B00;
  background: #fff7e6;
}

.status-tag.pending {
  color: #999;
  background: #f5f5f5;
}

.status-tag.completed {
  color: #07c160;
  background: #e8f5e9;
}

.card-body {
  margin-bottom: 16rpx;
}

.factory-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.cargo-info {
  font-size: 24rpx;
  color: #888;
  display: block;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f8f8f8;
}

.create-time {
  font-size: 22rpx;
  color: #bbb;
}

.amount {
  font-size: 30rpx;
  color: #e53935;
  font-weight: bold;
}

.amount-unquoted {
  font-size: 24rpx;
  color: #999;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-btn {
  font-size: 22rpx;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
  background: #fff2f0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: #FF6B00;
  color: #fff;
  padding: 20rpx 80rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
  font-size: 28rpx;
  color: #999;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF6B00;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
