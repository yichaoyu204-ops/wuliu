.container {
  background: #f5f7fa;
  min-height: 100vh;
}

/* 顶部提示 */
.tip-bar {
  background: #fff7e6;
  padding: 16rpx 24rpx;
  border-bottom: 1rpx solid #ffe7ba;
}

.tip-text {
  font-size: 24rpx;
  color: #fa8c16;
}

/* 运单列表 */
.shipment-list {
  padding: 20rpx 24rpx;
}

.shipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.shipment-id {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
  font-family: monospace;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-tag.active {
  color: #FF6B00;
  background: #fff7e6;
}

.status-tag.pending {
  color: #999;
  background: #f5f5f5;
}

.status-tag.completed {
  color: #07c160;
  background: #e8f5e9;
}

.card-body {
  margin-bottom: 16rpx;
}

.factory-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.cargo-info {
  font-size: 24rpx;
  color: #888;
  display: block;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f8f8f8;
}

.create-time {
  font-size: 22rpx;
  color: #bbb;
}

.amount {
  font-size: 30rpx;
  color: #e53935;
  font-weight: bold;
}

.amount-unquoted {
  font-size: 24rpx;
  color: #999;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.delete-btn {
  font-size: 22rpx;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
  background: #fff2f0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  line-height: 1.4;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 48rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: #FF6B00;
  color: #fff;
  padding: 20rpx 80rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 加载中 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0;
  font-size: 28rpx;
  color: #999;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #FF6B00;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */
