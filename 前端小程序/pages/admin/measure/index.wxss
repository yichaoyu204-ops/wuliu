.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
  padding-bottom: 160rpx;
}

/* 货物信息卡 */
.info-card {
  background: #e8f0fe;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border-left: 6rpx solid #FF6B00;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.info-label {
  font-size: 24rpx;
  color: #555;
  width: 120rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
}

.info-value.hint {
  color: #888;
  font-size: 24rpx;
}

.mono {
  font-family: monospace;
}

/* 分区 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #aaa;
  display: block;
  margin-bottom: 24rpx;
}

/* 表单 */
.field {
  margin-bottom: 24rpx;
}

.label {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #1a1a1a;
  background: #fafafa;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
}

.input-unit-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.flex1 {
  flex: 1;
}

.unit-tag {
  background: #e8f0fe;
  color: #FF6B00;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 8rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.photo-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

.photo-del {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  background: rgba(0,0,0,0.6);
  color: #fff;
  font-size: 22rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: #fafafa;
}

.add-icon {
  font-size: 48rpx;
}

.add-text {
  font-size: 22rpx;
  color: #888;
}

/* 费用计算 */
.fee-group {
  margin-bottom: 24rpx;
}

.fee-group-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
  display: block;
}

.fee-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.fee-left {
  flex: 1;
  margin-right: 16rpx;
}

.fee-name {
  font-size: 28rpx;
  color: #1a1a1a;
  display: block;
}

.fee-detail {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
  display: block;
}

.fee-amount {
  font-size: 28rpx;
  color: #E53935;
  font-weight: 500;
  white-space: nowrap;
}

/* 附加费用项 */
.extra-fee-item {
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #fafafa;
  border-radius: 12rpx;
}

.extra-fee-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  flex-shrink: 0;
}

.checkbox.checked {
  background: #FF6B00;
  border-color: #FF6B00;
}

.extra-fee-name {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

.extra-fee-amount {
  font-size: 28rpx;
  color: #E53935;
  font-weight: 500;
}

.extra-fee-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  margin-left: 48rpx;
}

.extra-fee-body {
  margin-top: 12rpx;
  margin-left: 48rpx;
}

/* 子费用行 */
.sub-fee-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid #eee;
}

.sub-fee-name {
  font-size: 26rpx;
  color: #555;
  width: 120rpx;
  flex-shrink: 0;
}

.sub-fee-inputs {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
  justify-content: flex-end;
}

.sub-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 6rpx 10rpx;
  font-size: 24rpx;
  text-align: center;
  background: #fff;
}

.sub-input.price {
  width: 100rpx;
}

.sub-input.qty {
  width: 80rpx;
}

.sub-unit {
  font-size: 22rpx;
  color: #888;
}

.sub-multiply, .sub-equals {
  font-size: 24rpx;
  color: #999;
}

.sub-amount {
  font-size: 26rpx;
  color: #E53935;
  font-weight: 500;
  min-width: 80rpx;
  text-align: right;
}

/* 行内输入 */
.inline-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
  font-size: 26rpx;
  color: #555;
}

.inline-input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 6rpx 12rpx;
  font-size: 26rpx;
  width: 120rpx;
  text-align: center;
  background: #fff;
}

.inline-input.wide {
  width: 240rpx;
}

/* 费用总计 */
.fee-total-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-top: 2rpx solid #FF6B00;
  margin-top: 16rpx;
}

.fee-total-label {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.fee-total-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #E53935;
}

/* 底部提交 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.submit-btn {
  background: #FF6B00;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-disabled {
  background: #aac4f0;
}

/* 支付弹窗 */
.pay-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
}

.pay-content {
  position: relative;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx;
  width: 560rpx;
  text-align: center;
  z-index: 1;
}

.pay-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.pay-amount {
  font-size: 56rpx;
  font-weight: bold;
  color: #E53935;
  margin-bottom: 16rpx;
}

.pay-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}

.pay-qr-placeholder {
  width: 320rpx;
  height: 320rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin: 0 auto 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-qr-text {
  font-size: 28rpx;
  color: #999;
}

.pay-actions {
  display: flex;
  gap: 24rpx;
}

.pay-btn {
  flex: 1;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
}

.pay-btn-secondary {
  background: #f5f5f5;
  color: #666;
}

.pay-btn-primary {
  background: #FF6B00;
  color: #fff;
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */

/* === No Emoji UI Icons === */
.empty-icon,
.ai-icon,
.upload-icon,
.add-icon,
.ai-result-icon,
.status-icon {
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  font-size: 0 !important;
  line-height: 1;
  color: transparent !important;
  background: transparent;
}

.empty-icon,
.empty-line-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #fbfaf7;
}

.empty-icon::before,
.empty-line-icon::before {
  content: '';
  position: absolute;
  left: 22rpx;
  top: 28rpx;
  width: 50rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #14213d;
  box-shadow: 0 18rpx 0 #ff6b00;
}

.empty-icon::after,
.empty-line-icon::after {
  content: '';
  position: absolute;
  left: 22rpx;
  bottom: 20rpx;
  width: 34rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #d8dee8;
}

.ai-icon,
.upload-icon,
.add-icon,
.ai-line-icon,
.upload-line-icon,
.add-line-icon {
  width: 92rpx;
  height: 72rpx;
  margin-bottom: 18rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 16rpx;
  background: #fff7ef;
}

.ai-icon::before,
.upload-icon::before,
.add-icon::before,
.ai-line-icon::before,
.upload-line-icon::before,
.add-line-icon::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 50%;
  background: #fffefa;
}

.ai-icon::after,
.upload-icon::after,
.add-icon::after,
.ai-line-icon::after,
.upload-line-icon::after,
.add-line-icon::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: -12rpx;
  width: 30rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #ff6b00;
}

.ai-result-icon {
  width: 58rpx;
  height: 58rpx;
  margin: 0 20rpx 0 0;
  border-radius: 50%;
  color: #fff !important;
  text-align: center;
  line-height: 58rpx;
  font-size: 30rpx !important;
  font-weight: 900;
  background: #0f766e;
}

.ai-result-icon.warning {
  background: #d97706;
}

.status-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(255,255,255,0.34);
  background: rgba(255,255,255,0.14);
  margin: 0 24rpx 0 0;
}

.status-icon::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 24rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #fff;
  box-shadow: 0 16rpx 0 #fca311;
}

.warning-text::before,
.payment-tip text::before {
  content: '!';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #fff1dc;
  color: #9a4b10;
  font-size: 20rpx;
  font-weight: 900;
}

.wechat-icon {
  display: none !important;
}

/* === End No Emoji UI Icons === */
