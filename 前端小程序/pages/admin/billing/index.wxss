.container {
  background: #f5f7fa;
  min-height: 100vh;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: #FF6B00;
  padding: 32rpx 24rpx;
  padding-bottom: 40rpx;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-divider {
  width: 1rpx;
  background: rgba(255,255,255,0.3);
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 8rpx;
}

.stats-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.stats-amount.unpaid {
  color: #ffeb3b;
}

/* Tab */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-active {
  color: #FF6B00;
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: #FF6B00;
  border-radius: 2rpx;
}

/* 列表 */
.bill-list {
  padding: 20rpx 24rpx;
}

.bill-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
}

.bill-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.bill-id {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 500;
  font-family: monospace;
}

.bill-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.bill-status.unpaid {
  color: #e53935;
  background: #ffebee;
}

.bill-status.paid {
  color: #07c160;
  background: #e8f5e9;
}

.bill-factory {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 4rpx;
}

.bill-phone {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.bill-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 1rpx solid #f8f8f8;
}

.bill-type {
  font-size: 24rpx;
  color: #888;
}

.bill-amount {
  font-size: 32rpx;
  color: #1a1a1a;
  font-weight: bold;
}

.mark-paid-btn {
  margin-top: 16rpx;
  text-align: center;
  padding: 16rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 120rpx 0;
  font-size: 28rpx;
  color: #999;
}

/* 月结操作 */
.action-bar {
  padding: 20rpx 24rpx;
}

.btn-monthly {
  text-align: center;
  padding: 22rpx;
  background: #FF6B00;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 998;
}

.modal-content {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  z-index: 999;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  text-align: center;
  margin-bottom: 32rpx;
  color: #1a1a1a;
}

.modal-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.modal-picker {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #1a1a1a;
}

.modal-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 40rpx;
  line-height: 40rpx;
}

.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn-cancel {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.modal-btn-confirm {
  flex: 1;
  text-align: center;
  padding: 22rpx;
  background: #FF6B00;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn-confirm.btn-disabled {
  background: #FFCC80;
}
