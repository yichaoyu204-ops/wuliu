<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-bar">
    <view class="stats-item">
      <text class="stats-label">未付总额</text>
      <text class="stats-amount unpaid">¥{{totalUnpaid.toFixed(2)}}</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-label">已付总额</text>
      <text class="stats-amount paid">¥{{totalPaid.toFixed(2)}}</text>
    </view>
  </view>

  <!-- 月结操作 -->
  <view class="action-bar">
    <view class="btn-monthly" bindtap="showMonthlyModal">生成月结账单</view>
  </view>

  <!-- Tab -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="key"
      class="tab-item {{activeTab === item.key ? 'tab-active' : ''}}"
      bindtap="switchTab"
      data-key="{{item.key}}"
    >{{item.label}}</view>
  </view>

  <!-- 列表 -->
  <view class="bill-list" wx:if="{{!loading}}">
    <view
      wx:for="{{filteredBills}}"
      wx:key="_id"
      class="bill-card"
    >
      <view class="bill-header">
        <text class="bill-id">{{item._id}}</text>
        <text class="bill-status {{item.status}}">{{item.status === 'unpaid' ? '待付' : '已付'}}</text>
      </view>
      <view class="bill-factory">{{item.contacts.contact1Name || '——'}}</view>
      <view class="bill-phone">客户：{{item.clientPhone || '——'}}</view>
      <view class="bill-footer">
        <text class="bill-type">{{item.paymentType === 'spot' ? '现结' : '月结'}}</text>
        <text class="bill-amount">¥{{item.totalAmount != null ? item.totalAmount.toFixed(2) : '0.00'}}</text>
      </view>
      <view
        wx:if="{{item.status === 'unpaid'}}"
        class="mark-paid-btn"
        bindtap="markPaid"
        data-id="{{item._id}}"
      >标记已付</view>
    </view>

    <view class="empty-state" wx:if="{{filteredBills.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无{{activeTab === 'unpaid' ? '待付' : (activeTab === 'paid' ? '已付' : '')}}账单</text>
    </view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 月结合并弹窗 -->
  <view class="modal-mask" wx:if="{{monthlyModalVisible}}" bindtap="hideMonthlyModal"></view>
  <view class="modal-content" wx:if="{{monthlyModalVisible}}">
    <view class="modal-title">生成月结账单</view>
    <view class="modal-row">
      <text class="modal-label">月份</text>
      <picker mode="date" fields="month" value="{{monthlyBatch}}" bindchange="onMonthlyBatchChange">
        <view class="modal-picker">{{monthlyBatch || '请选择月份'}}</view>
      </picker>
    </view>
    <view class="modal-row">
      <text class="modal-label">客户手机号</text>
      <input class="modal-input" type="number" placeholder="输入客户手机号" value="{{monthlyPhone}}" bindinput="onMonthlyPhoneChange" />
    </view>
    <view class="modal-actions">
      <view class="modal-btn-cancel" bindtap="hideMonthlyModal">取消</view>
      <view class="modal-btn-confirm {{monthlySubmitting ? 'btn-disabled' : ''}}" bindtap="doCreateMonthlyBill">
        {{monthlySubmitting ? '生成中...' : '确认生成'}}
      </view>
    </view>
  </view>
</view>
