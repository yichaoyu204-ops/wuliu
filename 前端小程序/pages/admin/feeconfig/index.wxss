.container {
  padding: 24rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #888;
  margin-top: 6rpx;
  display: block;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-text {
  color: #888;
  font-size: 28rpx;
  margin-top: 16rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.card-disabled {
  opacity: 0.55;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.cat-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.tag-required {
  background: #fff3e0;
  color: #e65100;
}

.tag-optional {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-disabled {
  background: #f5f5f5;
  color: #999;
}

.card-body {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.detail-row {
  display: block;
  font-size: 26rpx;
  color: #555;
  margin-bottom: 8rpx;
  line-height: 1.6;
}

.desc {
  color: #888;
  font-style: italic;
}

.mono {
  font-family: monospace;
  background: #f5f5f5;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

/* 排序 */
.sort-row {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
  gap: 12rpx;
}

.sort-label {
  font-size: 26rpx;
  color: #555;
}

.sort-input {
  width: 100rpx;
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  font-size: 26rpx;
  text-align: center;
}

.sort-hint {
  font-size: 22rpx;
  color: #aaa;
}

/* 新增按钮 */
.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  border: 2rpx dashed #FF6B00;
  border-radius: 16rpx;
  padding: 36rpx;
  color: #FF6B00;
  font-size: 30rpx;
  margin-top: 8rpx;
}

.add-icon {
  font-size: 40rpx;
  font-weight: 300;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.modal {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.modal-close {
  font-size: 32rpx;
  color: #888;
  padding: 8rpx;
}

.modal-body {
  flex: 1;
  padding: 24rpx 32rpx;
}

.field {
  margin-bottom: 28rpx;
}

.field-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.label {
  font-size: 26rpx;
  color: #555;
  display: block;
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: #fafafa;
}

.picker-view {
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  background: #fafafa;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  color: #888;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f0f0f0;
}

.btn-cancel {
  flex: 1;
  padding: 26rpx;
  border-radius: 50rpx;
  border: 1rpx solid #ddd;
  text-align: center;
  font-size: 30rpx;
  color: #555;
}

.btn-submit {
  flex: 2;
  padding: 26rpx;
  border-radius: 50rpx;
  background: #FF6B00;
  text-align: center;
  font-size: 30rpx;
  color: #fff;
  font-weight: 600;
}

.btn-disabled {
  background: #aac4f0;
}
