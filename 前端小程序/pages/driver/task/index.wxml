<view class="container">
  <view class="header">
    <text class="header-title">司机任务</text>
    <text class="header-desc">扫描业务编号更新物流节点</text>
  </view>

  <view class="search-bar">
    <input class="search-input" placeholder="输入业务编号" value="{{keyword}}" bindinput="onInput" />
    <view class="search-btn" bindtap="search">查询</view>
    <view class="scan-btn" bindtap="scanCode">扫码</view>
  </view>

  <view class="shipment-card" wx:if="{{shipment}}">
    <view class="card-header">
      <text class="card-id">{{shipment.cargoInfo.waybillNo || shipment._id}}</text>
      <text class="card-factory">{{shipment.contacts.contact1Name || '——'}}</text>
    </view>

    <view class="node-info">
      <text class="node-label">当前节点</text>
      <text class="node-value {{currentNode ? 'active' : ''}}">{{currentNode ? currentNode.nodeName : '已完成'}}</text>
    </view>

    <view class="node-info" wx:if="{{nextNode}}">
      <text class="node-label">下一步</text>
      <text class="node-value next">{{nextNode.nodeName}}</text>
    </view>

    <view class="action-area" wx:if="{{canAdvance}}">
      <view class="btn-advance {{advancing ? 'disabled' : ''}}" bindtap="advanceNode">
        {{advancing ? '更新中...' : '确认完成：' + currentNode.nodeName}}
      </view>
    </view>

    <view class="complete-area" wx:if="{{!canAdvance}}">
      <text class="complete-text">所有物流节点已完成</text>
    </view>
  </view>

  <view class="empty" wx:if="{{!shipment && hasSearched}}">
    <view class="empty-icon empty-line-icon"></view>
    <text class="empty-text">未找到该运单</text>
  </view>

  <view class="hint" wx:if="{{!shipment && !hasSearched}}">
    <text class="hint-text">输入业务编号或扫码查询货物</text>
  </view>
</view>
