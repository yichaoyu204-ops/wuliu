.container {
  padding: 40rpx 32rpx;
  background: #f7f8fa;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.scan-btn {
  background: #333;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.shipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-header {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-id {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.card-factory {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.node-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.node-info:last-of-type {
  border-bottom: none;
}

.node-label {
  font-size: 28rpx;
  color: #555;
}

.node-value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.node-value.active {
  color: #FF6B00;
}

.node-value.next {
  color: #4CAF50;
}

.action-area {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-advance {
  background: #FF6B00;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-advance.disabled {
  background: #FFCC80;
}

.complete-area {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.complete-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 600;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.hint {
  text-align: center;
  padding: 120rpx 40rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #bbb;
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */
