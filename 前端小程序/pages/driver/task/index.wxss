.container {
  padding: 40rpx 32rpx;
  background: #f7f8fa;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 40rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.scan-btn {
  background: #333;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.shipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.card-header {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-id {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.card-factory {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.node-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.node-info:last-of-type {
  border-bottom: none;
}

.node-label {
  font-size: 28rpx;
  color: #555;
}

.node-value {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.node-value.active {
  color: #FF6B00;
}

.node-value.next {
  color: #4CAF50;
}

.action-area {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-advance {
  background: #FF6B00;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-advance.disabled {
  background: #FFCC80;
}

.complete-area {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.complete-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 600;
}

.empty {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  display: block;
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.hint {
  text-align: center;
  padding: 120rpx 40rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #bbb;
}
