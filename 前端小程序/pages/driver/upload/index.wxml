<view class="container">
  <!-- 顶部说明 -->
  <view class="header">
    <text class="header-title">拍照上传进仓单</text>
    <text class="header-desc">拍摄清晰的进仓单照片，AI将自动识别信息</text>
  </view>

  <!-- 拍照/选图入口 -->
  <view class="upload-section" wx:if="{{!hasImage}}">
    <view class="upload-card" bindtap="chooseImage">
      <view class="upload-icon upload-line-icon"></view>
      <text class="upload-label">点击拍照或选图</text>
    </view>
  </view>

  <!-- 已选图片预览 + 重新上传 -->
  <view class="preview-section" wx:if="{{hasImage}}">
    <image class="preview-img" src="{{imageUrl}}" mode="aspectFit" bindtap="previewImage" />
    <text class="preview-retry" bindtap="chooseImage">重新上传</text>
  </view>

  <!-- AI 识别状态 -->
  <view class="ai-status" wx:if="{{aiLoading}}">
    <text class="ai-loading">AI 识别中...</text>
  </view>

  <!-- 识别结果表单 -->
  <view class="form-section" wx:if="{{hasImage && !aiLoading}}">
    <view class="section-title">识别结果（请核对修改）</view>

    <view class="form-row {{manualReview.waybillNo ? 'row-warning' : ''}}">
      <text class="form-label">业务编号</text>
      <input class="form-input" type="text" placeholder="如 26MH642064" value="{{cargoInfo.waybillNo}}" bindinput="onWaybillNoChange" />
    </view>

    <view class="form-row {{manualReview.pieces ? 'row-warning' : ''}}">
      <text class="form-label">件数</text>
      <input class="form-input" type="number" placeholder="请输入件数" value="{{cargoInfo.pieces}}" bindinput="onPiecesChange" />
      <picker class="form-picker" bindchange="onPiecesUnitChange" value="{{piecesUnitIndex}}" range="{{unitOptions.pieces}}">
        <view>{{cargoInfo.piecesUnit || 'CTNS'}}</view>
      </picker>
    </view>

    <view class="form-row {{manualReview.weight ? 'row-warning' : ''}}">
      <text class="form-label">毛重</text>
      <input class="form-input" type="digit" placeholder="请输入毛重" value="{{cargoInfo.grossWeight}}" bindinput="onWeightChange" />
      <picker class="form-picker" bindchange="onWeightUnitChange" value="{{weightUnitIndex}}" range="{{unitOptions.weight}}">
        <view>{{cargoInfo.weightUnit || 'KGS'}}</view>
      </picker>
    </view>

    <view class="form-row {{manualReview.volume ? 'row-warning' : ''}}">
      <text class="form-label">体积</text>
      <input class="form-input" type="digit" placeholder="请输入体积" value="{{cargoInfo.volume}}" bindinput="onVolumeChange" />
      <picker class="form-picker" bindchange="onVolumeUnitChange" value="{{volumeUnitIndex}}" range="{{unitOptions.volume}}">
        <view>{{cargoInfo.volumeUnit || 'CBM'}}</view>
      </picker>
    </view>

    <view class="form-row {{manualReview.marks ? 'row-warning' : ''}}">
      <text class="form-label">唛头</text>
      <input class="form-input" type="text" placeholder="请输入唛头" value="{{cargoInfo.marks}}" bindinput="onMarksChange" />
    </view>

    <view class="form-row">
      <text class="form-label">目的港</text>
      <input class="form-input" type="text" placeholder="" value="{{routing.destinationPort}}" bindinput="onDestinationPortChange" />
    </view>

    <view class="form-row">
      <text class="form-label">开航时间</text>
      <view class="form-picker-with-clear">
        <picker mode="date" class="form-picker-wide" bindchange="onDepartureTimeChange" value="{{routing.departureTime}}">
          <view class="date-picker-text {{routing.departureTime ? '' : 'placeholder'}}">{{routing.departureTime || '请选择开航日期'}}</view>
        </picker>
        <text class="clear-btn" wx:if="{{routing.departureTime}}" bindtap="clearDepartureTime">清空</text>
      </view>
    </view>

    <view class="form-row">
      <text class="form-label">最晚进仓</text>
      <picker mode="date" class="form-picker-date" bindchange="onLatestDeliveryDateChange" value="{{latestDeliveryDate}}">
        <view class="date-picker-text">{{latestDeliveryDate || '请选择日期'}}</view>
      </picker>
      <picker mode="time" class="form-picker-time" bindchange="onLatestDeliveryTimeChange" value="{{latestDeliveryTime}}">
        <view class="date-picker-text">{{latestDeliveryTime || '请选择时间'}}</view>
      </picker>
    </view>

    <!-- 联系人 -->
    <view class="section-title" style="margin-top:40rpx">联系人</view>

    <view class="form-row">
      <text class="form-label">联系人</text>
      <input class="form-input" type="text" placeholder="请输入联系人姓名" value="{{contacts.contactPerson}}" bindinput="onContactPersonChange" />
    </view>
    <view class="form-row">
      <text class="form-label">手机号</text>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{contacts.contactPhone}}" bindinput="onContactPhoneChange" />
    </view>

    <!-- 提交 -->
    <view class="submit-area">
      <view class="btn-submit {{submitting ? 'btn-disabled' : ''}}" bindtap="onSubmit">
        {{submitting ? '提交中...' : '提交待复核'}}
      </view>
      <text class="submit-hint">提交后管理员将复核并创建正式运单</text>
    </view>
  </view>
</view>
