.container {
  padding: 40rpx 32rpx;
  background: #f7f8fa;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.upload-section {
  margin-bottom: 40rpx;
}

.upload-card {
  background: #fff;
  border: 2rpx dashed #FF6B00;
  border-radius: 16rpx;
  padding: 80rpx;
  text-align: center;
}

.upload-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.upload-label {
  display: block;
  font-size: 30rpx;
  color: #FF6B00;
  font-weight: 600;
}

.preview-section {
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.preview-img {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
}

.preview-retry {
  font-size: 28rpx;
  color: #FF6B00;
  margin-top: 16rpx;
  display: block;
}

.ai-status {
  text-align: center;
  padding: 40rpx;
}

.ai-loading {
  font-size: 28rpx;
  color: #FF6B00;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.form-row.row-warning {
  background: #FFF8F0;
  margin: 0 -32rpx;
  padding: 20rpx 32rpx;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #555;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  height: 48rpx;
  line-height: 48rpx;
}

.form-picker {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  color: #FF6B00;
  flex-shrink: 0;
}

.form-picker-wide {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

.form-picker-date {
  width: 220rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  flex-shrink: 0;
}

.form-picker-time {
  width: 160rpx;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  flex-shrink: 0;
}

.date-picker-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.date-picker-text.placeholder {
  color: #999;
}

.form-picker-with-clear {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.clear-btn {
  font-size: 24rpx;
  color: #E53935;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
}

.submit-area {
  margin-top: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.btn-submit {
  background: #FF6B00;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-submit.btn-disabled {
  background: #FFCC80;
}

.submit-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */

/* === No Emoji UI Icons === */
.empty-icon,
.ai-icon,
.upload-icon,
.add-icon,
.ai-result-icon,
.status-icon {
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  font-size: 0 !important;
  line-height: 1;
  color: transparent !important;
  background: transparent;
}

.empty-icon,
.empty-line-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #fbfaf7;
}

.empty-icon::before,
.empty-line-icon::before {
  content: '';
  position: absolute;
  left: 22rpx;
  top: 28rpx;
  width: 50rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #14213d;
  box-shadow: 0 18rpx 0 #ff6b00;
}

.empty-icon::after,
.empty-line-icon::after {
  content: '';
  position: absolute;
  left: 22rpx;
  bottom: 20rpx;
  width: 34rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #d8dee8;
}

.ai-icon,
.upload-icon,
.add-icon,
.ai-line-icon,
.upload-line-icon,
.add-line-icon {
  width: 92rpx;
  height: 72rpx;
  margin-bottom: 18rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 16rpx;
  background: #fff7ef;
}

.ai-icon::before,
.upload-icon::before,
.add-icon::before,
.ai-line-icon::before,
.upload-line-icon::before,
.add-line-icon::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 50%;
  background: #fffefa;
}

.ai-icon::after,
.upload-icon::after,
.add-icon::after,
.ai-line-icon::after,
.upload-line-icon::after,
.add-line-icon::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: -12rpx;
  width: 30rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #ff6b00;
}

.ai-result-icon {
  width: 58rpx;
  height: 58rpx;
  margin: 0 20rpx 0 0;
  border-radius: 50%;
  color: #fff !important;
  text-align: center;
  line-height: 58rpx;
  font-size: 30rpx !important;
  font-weight: 900;
  background: #0f766e;
}

.ai-result-icon.warning {
  background: #d97706;
}

.status-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(255,255,255,0.34);
  background: rgba(255,255,255,0.14);
  margin: 0 24rpx 0 0;
}

.status-icon::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 24rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #fff;
  box-shadow: 0 16rpx 0 #fca311;
}

.warning-text::before,
.payment-tip text::before {
  content: '!';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #fff1dc;
  color: #9a4b10;
  font-size: 20rpx;
  font-weight: 900;
}

.wechat-icon {
  display: none !important;
}

/* === End No Emoji UI Icons === */
