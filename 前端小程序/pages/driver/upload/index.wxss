.container {
  padding: 40rpx 32rpx;
  background: #f7f8fa;
  min-height: 100vh;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.header {
  margin-bottom: 40rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.upload-section {
  margin-bottom: 40rpx;
}

.upload-card {
  background: #fff;
  border: 2rpx dashed #FF6B00;
  border-radius: 16rpx;
  padding: 80rpx;
  text-align: center;
}

.upload-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.upload-label {
  display: block;
  font-size: 30rpx;
  color: #FF6B00;
  font-weight: 600;
}

.preview-section {
  margin-bottom: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.preview-img {
  width: 100%;
  height: 400rpx;
  border-radius: 8rpx;
}

.preview-retry {
  font-size: 28rpx;
  color: #FF6B00;
  margin-top: 16rpx;
  display: block;
}

.ai-status {
  text-align: center;
  padding: 40rpx;
}

.ai-loading {
  font-size: 28rpx;
  color: #FF6B00;
}

.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.form-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-row:last-child {
  border-bottom: none;
}

.form-row.row-warning {
  background: #FFF8F0;
  margin: 0 -32rpx;
  padding: 20rpx 32rpx;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #555;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  height: 48rpx;
  line-height: 48rpx;
}

.form-picker {
  width: 120rpx;
  text-align: right;
  font-size: 26rpx;
  color: #FF6B00;
  flex-shrink: 0;
}

.form-picker-wide {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
}

.form-picker-date {
  width: 220rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  flex-shrink: 0;
}

.form-picker-time {
  width: 160rpx;
  margin-left: 16rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  flex-shrink: 0;
}

.date-picker-text {
  font-size: 28rpx;
  color: #1a1a1a;
}

.date-picker-text.placeholder {
  color: #999;
}

.form-picker-with-clear {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.clear-btn {
  font-size: 24rpx;
  color: #E53935;
  margin-left: 16rpx;
  padding: 4rpx 12rpx;
}

.submit-area {
  margin-top: 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.btn-submit {
  background: #FF6B00;
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-submit.btn-disabled {
  background: #FFCC80;
}

.submit-hint {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}
