.container {
  min-height: 100vh;
  background: #f3f5f8;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

/* 搜索区 */
.search-section {
  position: relative;
  overflow: hidden;
  background: linear-gradient(145deg, #14213d 0%, #243655 58%, #f3f5f8 58%);
  padding: 34rpx 28rpx 62rpx;
}

.search-section::before {
  content: '';
  position: absolute;
  right: -140rpx;
  top: -120rpx;
  width: 360rpx;
  height: 360rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.search-section::after {
  content: '';
  position: absolute;
  left: 28rpx;
  bottom: 88rpx;
  width: 120rpx;
  height: 6rpx;
  background: #fca311;
  border-radius: 6rpx;
}

.top-bar {
  display: flex;
  position: relative;
  z-index: 1;
  justify-content: space-between;
  align-items: flex-start;
  padding: 4rpx 0 30rpx;
}

.brand-block {
  display: flex;
  flex-direction: column;
}

.brand-kicker {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.55);
  font-weight: 700;
}

.brand-title {
  margin-top: 6rpx;
  font-size: 34rpx;
  color: #fff;
  font-weight: 800;
  line-height: 1.15;
}

.logout-btn {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  padding: 12rpx 18rpx;
  border: 1rpx solid rgba(255,255,255,0.24);
  border-radius: 6rpx;
  background: rgba(255,255,255,0.08);
}

.search-title {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  margin-bottom: 26rpx;
}

.search-heading {
  font-size: 48rpx;
  color: #fff;
  font-weight: 800;
  line-height: 1.15;
}

.search-subheading {
  margin-top: 10rpx;
  font-size: 25rpx;
  color: rgba(255, 255, 255, 0.68);
}

.search-box {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 16rpx 16rpx 16rpx 26rpx;
  box-shadow: 0 18rpx 42rpx rgba(20, 33, 61, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.78);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  height: 58rpx;
  line-height: 58rpx;
  min-width: 0;
}

.search-input::placeholder {
  color: #bbb;
}

.search-btn {
  background: #fca311;
  color: #14213d;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  margin-left: 14rpx;
  font-weight: 800;
  flex-shrink: 0;
}

/* 待办流程提醒 */
.pending-banner {
  margin: -26rpx 24rpx 22rpx;
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(20, 33, 61, 0.06);
  border: 1rpx solid #e7ecf2;
  border-left: 8rpx solid #fca311;
}

.pending-content {
  display: flex;
  align-items: center;
}

.pending-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #14213d;
  color: #fca311;
  text-align: center;
  line-height: 42rpx;
  font-size: 28rpx;
  font-weight: 800;
  margin-right: 18rpx;
}

.pending-text {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.pending-count {
  font-size: 33rpx;
  font-weight: 700;
  color: #14213d;
}

.pending-desc {
  font-size: 28rpx;
  color: #445160;
}

.pending-arrow {
  font-size: 32rpx;
  color: #b8c0cc;
}

/* 功能入口 */
.feature-grid {
  display: flex;
  justify-content: space-around;
  padding: 0;
  margin: 0 24rpx 28rpx;
  gap: 14rpx;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 26rpx 8rpx 24rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 33, 61, 0.05);
  border: 1rpx solid #e7ecf2;
  transition: transform 0.2s;
  min-width: 0;
}

.feature-item:active {
  transform: scale(0.96);
}

.feature-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.feature-waybill .feature-icon {
  color: #14213d;
  background: #edf2f7;
}

.feature-scan .feature-icon {
  color: #0f766e;
  background: #e6f6f3;
}

.feature-service .feature-icon {
  color: #8a4b10;
  background: #fff2d9;
}

.feature-text {
  font-size: 24rpx;
  color: #344054;
  font-weight: 600;
}

/* 结果区 */
.result-section {
  padding: 0 24rpx 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #14213d;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

.shipment-card {
  background: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 33, 61, 0.05);
  border: 1rpx solid #e7ecf2;
}

.shipment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 18rpx;
}

.shipment-id {
  font-size: 30rpx;
  color: #14213d;
  font-weight: 800;
  font-family: monospace;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
  background: #fff2d9;
  color: #9a4b10;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tag.completed {
  background: #e8f5e9;
  color: #07c160;
}

.shipment-info {
  margin-bottom: 16rpx;
}

.factory-name {
  font-size: 30rpx;
  color: #1d2733;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.cargo-desc {
  font-size: 26rpx;
  color: #667085;
  display: block;
  line-height: 1.45;
}

.shipment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.route-name {
  font-size: 24rpx;
  color: #667085;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.create-time {
  font-size: 24rpx;
  color: #98a2b3;
  flex-shrink: 0;
}

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 历史查询 */
.history-section {
  padding: 0 24rpx 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.4;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
}

.history-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 空状态引导 */
.empty-section {
  padding: 72rpx 48rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 58rpx 36rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 33, 61, 0.05);
  border: 1rpx solid #e7ecf2;
}

.empty-visual {
  position: relative;
  width: 176rpx;
  height: 104rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #d8dee8;
  border-radius: 12rpx;
  background: #f8fafc;
}

.empty-line {
  position: absolute;
  left: 30rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #14213d;
}

.empty-line-main {
  top: 32rpx;
  width: 88rpx;
}

.empty-line-sub {
  top: 52rpx;
  width: 118rpx;
  background: #fca311;
}

.empty-dot {
  position: absolute;
  bottom: -12rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #14213d;
}

.empty-dot-left {
  left: 34rpx;
}

.empty-dot-right {
  right: 34rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #14213d;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 32rpx;
}

.empty-tip {
  background: #fff4df;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

.empty-tip text {
  font-size: 26rpx;
  color: #8a4b10;
}

/* 联系人弹窗 */
.contact-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.contact-popup {
  width: 100%;
  background: #fff;
  border-radius: 18rpx 18rpx 0 0;
  padding: 32rpx 0 calc(120rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.contact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.contact-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.contact-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 0 24rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.contact-item:active {
  background: #f5f5f5;
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #14213d;
  margin-right: 24rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.contact-phone {
  font-size: 26rpx;
  color: #888;
}

.contact-arrow {
  font-size: 24rpx;
  color: #14213d;
  background: #edf2f7;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}
