.container {
  min-height: 100vh;
  background: #f8f7f4;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

/* 搜索区 */
.search-section {
  position: relative;
  overflow: hidden;
  background: #fffefa;
  padding: 24rpx 32rpx 34rpx;
  border-bottom: 1rpx solid #ece7df;
}

.search-section::before {
  display: none;
}

.search-section::after {
  display: none;
}

.top-bar {
  display: flex;
  position: relative;
  z-index: 1;
  justify-content: flex-end;
  align-items: center;
  min-height: 42rpx;
  padding-bottom: 22rpx;
}

.logout-btn {
  color: #697386;
  font-size: 24rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
  border: 1rpx solid #d9dee8;
  border-radius: 8rpx;
  background: #fff;
}

.search-title {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  margin-bottom: 28rpx;
}

.search-heading {
  font-size: 44rpx;
  color: #14213d;
  font-weight: 800;
  line-height: 1.15;
}

.search-subheading {
  margin-top: 10rpx;
  font-size: 27rpx;
  color: rgba(255, 255, 255, 0.7);
}

.search-box {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 14rpx;
  padding: 18rpx 16rpx 18rpx 28rpx;
  box-shadow: 0 12rpx 26rpx rgba(20, 33, 61, 0.1);
  border: 1rpx solid #ddd7cf;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 32rpx;
  color: #1a1a1a;
  height: 64rpx;
  line-height: 64rpx;
  min-width: 0;
}

.search-input::placeholder {
  color: #8e97a8;
}

.search-btn {
  background: #ff6b00;
  color: #fff;
  font-size: 32rpx;
  padding: 18rpx 34rpx;
  border-radius: 10rpx;
  margin-left: 14rpx;
  font-weight: 800;
  flex-shrink: 0;
}

/* 待办流程提醒 */
.pending-banner {
  margin: 24rpx 32rpx 0;
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(20, 33, 61, 0.06);
  border: 1rpx solid #e7ecf2;
  border-left: 8rpx solid #fca311;
}

.pending-content {
  display: flex;
  align-items: center;
}

.pending-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  background: #14213d;
  color: #fca311;
  text-align: center;
  line-height: 42rpx;
  font-size: 28rpx;
  font-weight: 800;
  margin-right: 18rpx;
}

.pending-text {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.pending-count {
  font-size: 33rpx;
  font-weight: 700;
  color: #14213d;
}

.pending-desc {
  font-size: 28rpx;
  color: #445160;
}

.pending-arrow {
  font-size: 32rpx;
  color: #b8c0cc;
}

/* 功能入口 */
.feature-grid {
  display: flex;
  justify-content: space-around;
  padding: 0;
  margin: 34rpx 32rpx 30rpx;
  gap: 18rpx;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 14rpx;
  padding: 34rpx 8rpx 30rpx;
  box-shadow: 0 10rpx 24rpx rgba(20, 33, 61, 0.08);
  border: 1rpx solid #e6e0d8;
  transition: transform 0.2s;
  min-width: 0;
}

.feature-item:active {
  transform: scale(0.96);
}

.feature-icon {
  position: relative;
  width: 96rpx;
  height: 86rpx;
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  background: transparent !important;
}

.feature-waybill .feature-icon {
  color: #ef5b24;
}

.feature-scan .feature-icon {
  color: #14213d;
}

.feature-service .feature-icon {
  color: #14213d;
}

.icon-waybill-line {
  position: absolute;
  left: 14rpx;
  width: 50rpx;
  height: 10rpx;
  border-radius: 5rpx;
  background: #ef5b24;
}

.icon-waybill-line.line-1 { top: 12rpx; }
.icon-waybill-line.line-2 { top: 32rpx; }
.icon-waybill-line.line-3 { top: 52rpx; }

.icon-waybill-arrow {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 26rpx;
  height: 34rpx;
  background: #c77b2b;
  border-radius: 4rpx;
}

.icon-waybill-arrow::after {
  content: '';
  position: absolute;
  left: -8rpx;
  bottom: -10rpx;
  width: 0;
  height: 0;
  border-left: 21rpx solid transparent;
  border-right: 21rpx solid transparent;
  border-top: 24rpx solid #c77b2b;
}

.scan-corner {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  border-color: #14213d;
  border-style: solid;
}

.scan-tl {
  left: 12rpx;
  top: 8rpx;
  border-width: 8rpx 0 0 8rpx;
}

.scan-tr {
  right: 12rpx;
  top: 8rpx;
  border-width: 8rpx 8rpx 0 0;
}

.scan-bl {
  left: 12rpx;
  bottom: 8rpx;
  border-width: 0 0 8rpx 8rpx;
}

.scan-br {
  right: 12rpx;
  bottom: 8rpx;
  border-width: 0 8rpx 8rpx 0;
}

.scan-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  background: #14213d;
}

.service-headset {
  width: 66rpx;
  height: 60rpx;
  border: 8rpx solid #14213d;
  border-bottom-color: transparent;
  border-radius: 50rpx 50rpx 24rpx 24rpx;
}

.service-ear {
  position: absolute;
  top: 34rpx;
  width: 14rpx;
  height: 30rpx;
  border-radius: 8rpx;
  background: #14213d;
}

.service-ear.left { left: 8rpx; }
.service-ear.right { right: 8rpx; }

.service-mic {
  position: absolute;
  right: 22rpx;
  bottom: 14rpx;
  width: 28rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #14213d;
}

.feature-text {
  font-size: 28rpx;
  color: #14213d;
  font-weight: 800;
  white-space: nowrap;
  line-height: 1.2;
}

/* 结果区 */
.result-section {
  padding: 0 24rpx 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #14213d;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

.shipment-card {
  background: #fff;
  border-radius: 14rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 26rpx rgba(20, 33, 61, 0.05);
  border: 1rpx solid #e7ecf2;
}

.shipment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 18rpx;
}

.shipment-id {
  font-size: 30rpx;
  color: #14213d;
  font-weight: 800;
  font-family: monospace;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 7rpx 16rpx;
  border-radius: 999rpx;
  font-weight: 700;
  background: #fff2d9;
  color: #9a4b10;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tag.completed {
  background: #e8f5e9;
  color: #07c160;
}

.shipment-info {
  margin-bottom: 16rpx;
}

.factory-name {
  font-size: 30rpx;
  color: #1d2733;
  font-weight: 700;
  display: block;
  margin-bottom: 8rpx;
}

.cargo-desc {
  font-size: 26rpx;
  color: #667085;
  display: block;
  line-height: 1.45;
}

.shipment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.route-name {
  font-size: 24rpx;
  color: #667085;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.create-time {
  font-size: 24rpx;
  color: #98a2b3;
  flex-shrink: 0;
}

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 历史查询 */
.history-section {
  padding: 0 24rpx 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.4;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
}

.history-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 空状态引导 */
.empty-section {
  padding: 116rpx 42rpx 72rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 64rpx 36rpx 58rpx;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.08);
  border: 1rpx solid #e6e0d8;
}

.empty-visual {
  position: relative;
  width: 210rpx;
  height: 118rpx;
  margin-bottom: 32rpx;
  border: 2rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #f8fafc;
}

.empty-line {
  position: absolute;
  left: 38rpx;
  height: 8rpx;
  border-radius: 8rpx;
  background: #14213d;
}

.empty-line-main {
  top: 38rpx;
  width: 88rpx;
}

.empty-line-sub {
  top: 60rpx;
  width: 126rpx;
  background: #fca311;
}

.empty-dot {
  position: absolute;
  bottom: -12rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #14213d;
}

.empty-dot-left {
  left: 42rpx;
}

.empty-dot-right {
  right: 42rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #14213d;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #697386;
  margin-bottom: 32rpx;
}

.empty-tip {
  background: #fff3df;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

.empty-tip text {
  font-size: 26rpx;
  color: #8a4b10;
}

/* 联系人弹窗 */
.contact-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.contact-popup {
  width: 100%;
  background: #fff;
  border-radius: 18rpx 18rpx 0 0;
  padding: 32rpx 0 calc(120rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.contact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.contact-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.contact-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 0 24rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.contact-item:active {
  background: #f5f5f5;
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #14213d;
  margin-right: 24rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.contact-phone {
  font-size: 26rpx;
  color: #888;
}

.contact-arrow {
  font-size: 24rpx;
  color: #14213d;
  background: #edf2f7;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
}

/* === Yiwu Line UI Polish v2 === */
.container {
  background: #f8f7f4;
  color: #14213d;
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.ai-card,
.ai-result-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.tip-bar,
.footer,
.manual-review-list,
.modal-content {
  border-radius: 16rpx;
  border: 1rpx solid #e8e1d8;
  box-shadow: 0 12rpx 28rpx rgba(20, 33, 61, 0.07);
}

.section,
.info-card,
.route-card,
.fee-card,
.measure-card,
.quote-card,
.workflow-card,
.shipment-card,
.bill-card,
.role-card,
.login-form,
.attachment-card,
.empty-box,
.empty-state,
.footer,
.modal-content {
  background: #fffefa;
}

.section-title,
.page-title,
.waybill-no,
.shipment-id,
.bill-id,
.factory-name,
.empty-title,
.role-name,
.login-title text,
.route-name,
.timeline-name,
.fee-total-label,
.quote-total-label,
.modal-title {
  color: #14213d;
  font-weight: 800;
}

.form-row,
.info-row,
.bill-footer,
.card-footer,
.card-body,
.fee-row,
.quote-row,
.measure-row {
  border-color: #eee8df;
}

.form-label,
.info-label,
.stats-label,
.bill-type,
.route-info,
.create-time,
.empty-desc,
.empty-hint,
.fee-calc,
.timeline-time,
.timeline-operator,
.measure-label {
  color: #697386;
}

.form-input,
.login-input,
.modal-input,
.modal-picker,
.form-picker-wide,
.form-picker-date,
.form-picker-time,
.date-picker-text {
  color: #14213d;
}

.form-input,
.login-input,
.modal-input,
.modal-picker {
  background: #fbfaf7;
  border: 1rpx solid #e8e1d8;
  border-radius: 10rpx;
}

.btn-submit,
.btn-primary,
.btn-login,
.btn-monthly,
.empty-btn,
.modal-btn-confirm,
.mark-paid-btn {
  background: #ff6b00;
  color: #fff;
  border-radius: 12rpx;
  font-weight: 800;
  box-shadow: 0 10rpx 22rpx rgba(255, 107, 0, 0.22);
}

.btn-secondary,
.modal-btn-cancel {
  background: #f2efe9;
  color: #374151;
  border-radius: 12rpx;
}

.status-tag,
.status-badge,
.bill-status,
.pay-tag,
.quote-status,
.manual-review-tag {
  border-radius: 999rpx;
  font-weight: 700;
}

.status-tag.active,
.status-badge.factory_confirmed,
.status-badge.mainline,
.pay-tag.spot,
.quote-status.sent,
.manual-review-tag {
  color: #9a4b10;
  background: #fff1dc;
}

.status-tag.completed,
.status-badge.admin_confirmed,
.status-badge.billed,
.bill-status.paid,
.quote-status.confirmed {
  color: #0f766e;
  background: #e6f6f3;
}

.bill-status.unpaid,
.amount,
.fee-total-amount,
.quote-total-amount {
  color: #d92d20;
}

.tab-bar {
  background: #fffefa;
  border-bottom: 1rpx solid #e8e1d8;
  box-shadow: 0 8rpx 22rpx rgba(20, 33, 61, 0.04);
}

.tab-active {
  color: #ff6b00;
  font-weight: 800;
}

.tab-active::after {
  background: #ff6b00;
}

.stats-bar,
.page-title {
  background: linear-gradient(135deg, #ff6b00 0%, #ff8a1f 100%);
  color: #fff;
}

.ai-card {
  border-style: solid;
  border-color: #ffd5b8;
}

.ai-icon,
.empty-icon {
  color: #ff6b00;
}

/* === End Yiwu Line UI Polish v2 === */

/* === No Emoji UI Icons === */
.empty-icon,
.ai-icon,
.upload-icon,
.add-icon,
.ai-result-icon,
.status-icon {
  position: relative;
  display: block;
  margin-left: auto;
  margin-right: auto;
  font-size: 0 !important;
  line-height: 1;
  color: transparent !important;
  background: transparent;
}

.empty-icon,
.empty-line-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  border: 3rpx solid #d8dee8;
  border-radius: 18rpx;
  background: #fbfaf7;
}

.empty-icon::before,
.empty-line-icon::before {
  content: '';
  position: absolute;
  left: 22rpx;
  top: 28rpx;
  width: 50rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #14213d;
  box-shadow: 0 18rpx 0 #ff6b00;
}

.empty-icon::after,
.empty-line-icon::after {
  content: '';
  position: absolute;
  left: 22rpx;
  bottom: 20rpx;
  width: 34rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #d8dee8;
}

.ai-icon,
.upload-icon,
.add-icon,
.ai-line-icon,
.upload-line-icon,
.add-line-icon {
  width: 92rpx;
  height: 72rpx;
  margin-bottom: 18rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 16rpx;
  background: #fff7ef;
}

.ai-icon::before,
.upload-icon::before,
.add-icon::before,
.ai-line-icon::before,
.upload-line-icon::before,
.add-line-icon::before {
  content: '';
  position: absolute;
  left: 30rpx;
  top: 20rpx;
  width: 26rpx;
  height: 26rpx;
  border: 4rpx solid #ff6b00;
  border-radius: 50%;
  background: #fffefa;
}

.ai-icon::after,
.upload-icon::after,
.add-icon::after,
.ai-line-icon::after,
.upload-line-icon::after,
.add-line-icon::after {
  content: '';
  position: absolute;
  left: 16rpx;
  top: -12rpx;
  width: 30rpx;
  height: 14rpx;
  border-radius: 8rpx 8rpx 0 0;
  background: #ff6b00;
}

.ai-result-icon {
  width: 58rpx;
  height: 58rpx;
  margin: 0 20rpx 0 0;
  border-radius: 50%;
  color: #fff !important;
  text-align: center;
  line-height: 58rpx;
  font-size: 30rpx !important;
  font-weight: 900;
  background: #0f766e;
}

.ai-result-icon.warning {
  background: #d97706;
}

.status-icon {
  width: 82rpx;
  height: 82rpx;
  border-radius: 18rpx;
  border: 3rpx solid rgba(255,255,255,0.34);
  background: rgba(255,255,255,0.14);
  margin: 0 24rpx 0 0;
}

.status-icon::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 24rpx;
  width: 40rpx;
  height: 6rpx;
  border-radius: 6rpx;
  background: #fff;
  box-shadow: 0 16rpx 0 #fca311;
}

.warning-text::before,
.payment-tip text::before {
  content: '!';
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  border-radius: 50%;
  background: #fff1dc;
  color: #9a4b10;
  font-size: 20rpx;
  font-weight: 900;
}

.wechat-icon {
  display: none !important;
}

/* === End No Emoji UI Icons === */
