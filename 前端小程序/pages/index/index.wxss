.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding-bottom: calc(112rpx + env(safe-area-inset-bottom));
}

/* 搜索区 */
.search-section {
  background: linear-gradient(180deg, #ff6b00 0%, #ff7f1a 76%, #f5f7fa 76%);
  padding: 28rpx 28rpx 58rpx;
}

.top-bar {
  display: flex;
  justify-content: flex-end;
  padding: 6rpx 0 18rpx;
}

.logout-btn {
  color: #fff;
  font-size: 24rpx;
  line-height: 1;
  padding: 10rpx 16rpx;
  border: 1rpx solid rgba(255,255,255,0.42);
  border-radius: 6rpx;
  background: rgba(255,255,255,0.1);
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 14rpx 14rpx 14rpx 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(120, 58, 8, 0.16);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  height: 58rpx;
  line-height: 58rpx;
  min-width: 0;
}

.search-input::placeholder {
  color: #bbb;
}

.search-btn {
  background: #ff6b00;
  color: #fff;
  font-size: 28rpx;
  padding: 15rpx 30rpx;
  border-radius: 12rpx;
  margin-left: 14rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 待办流程提醒 */
.pending-banner {
  margin: -28rpx 24rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.08);
  border-left: 8rpx solid #ff6b00;
}

.pending-content {
  display: flex;
  align-items: center;
}

.pending-icon {
  font-size: 38rpx;
  margin-right: 18rpx;
}

.pending-text {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.pending-count {
  font-size: 34rpx;
  font-weight: 700;
  color: #ff6b00;
}

.pending-desc {
  font-size: 28rpx;
  color: #445160;
}

.pending-arrow {
  font-size: 32rpx;
  color: #b8c0cc;
}

/* 功能入口 */
.feature-grid {
  display: flex;
  justify-content: space-around;
  padding: 0;
  margin: 0 24rpx 28rpx;
  gap: 16rpx;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 8rpx;
  box-shadow: 0 4rpx 18rpx rgba(31, 41, 55, 0.05);
  border: 1rpx solid #eef1f5;
  transition: transform 0.2s;
  min-width: 0;
}

.feature-item:active {
  transform: scale(0.96);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 14rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #344054;
  font-weight: 600;
}

/* 结果区 */
.result-section {
  padding: 0 24rpx 28rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

.shipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 18rpx rgba(31, 41, 55, 0.05);
  border: 1rpx solid #eef1f5;
}

.shipment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 18rpx;
}

.shipment-id {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  font-family: monospace;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  background: #fff3e0;
  color: #ff6b00;
  max-width: 210rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex-shrink: 0;
}

.status-tag.completed {
  background: #e8f5e9;
  color: #07c160;
}

.shipment-info {
  margin-bottom: 16rpx;
}

.factory-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.cargo-desc {
  font-size: 26rpx;
  color: #888;
  display: block;
  line-height: 1.45;
}

.shipment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
  gap: 20rpx;
}

.route-name {
  font-size: 24rpx;
  color: #999;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.create-time {
  font-size: 24rpx;
  color: #bbb;
  flex-shrink: 0;
}

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 历史查询 */
.history-section {
  padding: 0 24rpx 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.4;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
}

.history-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 空状态引导 */
.empty-section {
  padding: 72rpx 48rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 56rpx 36rpx;
  box-shadow: 0 4rpx 18rpx rgba(31, 41, 55, 0.05);
  border: 1rpx solid #eef1f5;
}

.empty-icon-large {
  font-size: 104rpx;
  margin-bottom: 28rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 32rpx;
}

.empty-tip {
  background: #fff8e1;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  line-height: 1.5;
}

.empty-tip text {
  font-size: 26rpx;
  color: #f57c00;
}

/* 联系人弹窗 */
.contact-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.contact-popup {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 0 calc(120rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.contact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.contact-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.contact-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 0 24rpx;
  border-radius: 12rpx;
  transition: background 0.2s;
}

.contact-item:active {
  background: #f5f5f5;
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B00;
  margin-right: 24rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.contact-phone {
  font-size: 26rpx;
  color: #888;
}

.contact-arrow {
  font-size: 36rpx;
}
