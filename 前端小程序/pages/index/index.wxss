.container {
  background: #f5f7fa;
  min-height: 100vh;
}

/* 搜索区 */
.search-section {
  background: linear-gradient(180deg, #FF6B00 0%, #FF6B00 70%, #f5f7fa 70%);
  padding: 30rpx 32rpx 60rpx;
}

.top-bar {
  display: flex;
  justify-content: flex-start;
  padding-top: 8rpx;
  padding-bottom: 16rpx;
}

.logout-btn {
  color: #fff;
  font-size: 24rpx;
  padding: 2rpx 10rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  border-radius: 6rpx;
  opacity: 0.85;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 50rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #1a1a1a;
  height: 48rpx;
  line-height: 48rpx;
}

.search-input::placeholder {
  color: #bbb;
}

.search-btn {
  background: #FF6B00;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.top-bar {
  display: flex;
  justify-content: flex-start;
  margin-bottom: 8rpx;
}

.logout-btn {
  color: #fff;
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  border-radius: 6rpx;
  opacity: 0.85;
}

/* 待办流程提醒 */
.pending-banner {
  margin: -30rpx 20rpx 20rpx;
  background: linear-gradient(135deg, #FF6B00 0%, #FF8F00 100%);
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 0, 0.25);
}

.pending-content {
  display: flex;
  align-items: center;
}

.pending-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
}

.pending-text {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.pending-count {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.pending-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.pending-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能入口 - 气泡玻璃态 */
.feature-grid {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 28rpx;
  margin: 0 20rpx 24rpx;
  gap: 20rpx;
}

.feature-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 24rpx 0;
  box-shadow: 0 8rpx 32rpx rgba(255,107,0,0.08), 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(255,255,255,0.6);
  transition: transform 0.2s;
}

.feature-item:active {
  transform: scale(0.96);
}

.feature-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 14rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.feature-text {
  font-size: 24rpx;
  color: #444;
  font-weight: 500;
}

/* 结果区 */
.result-section {
  padding: 0 24rpx 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
  font-weight: normal;
}

.shipment-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.shipment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.shipment-id {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  font-family: monospace;
}

.status-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  background: #FFF3E0;
  color: #FF6B00;
}

.status-tag.completed {
  background: #e8f5e9;
  color: #07c160;
}

.shipment-info {
  margin-bottom: 16rpx;
}

.factory-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.cargo-desc {
  font-size: 26rpx;
  color: #888;
}

.shipment-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.route-name {
  font-size: 24rpx;
  color: #999;
}

.create-time {
  font-size: 24rpx;
  color: #bbb;
}

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
}

/* 历史查询 */
.history-section {
  padding: 0 24rpx 24rpx;
}

.history-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
}

.history-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.4;
}

.history-text {
  flex: 1;
  font-size: 28rpx;
  color: #555;
}

.history-arrow {
  font-size: 28rpx;
  color: #ccc;
}

/* 空状态引导 */
.empty-section {
  padding: 60rpx 48rpx;
}

.empty-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.empty-icon-large {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 32rpx;
}

.empty-tip {
  background: #fff8e1;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
}

.empty-tip text {
  font-size: 26rpx;
  color: #f57c00;
}

/* 联系人弹窗 */
.contact-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.contact-popup {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx 0 calc(120rpx + env(safe-area-inset-bottom));
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.contact-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.contact-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.contact-close {
  font-size: 32rpx;
  color: #999;
  padding: 8rpx;
}

.contact-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin: 0 24rpx;
  border-radius: 16rpx;
  transition: background 0.2s;
}

.contact-item:active {
  background: #f5f5f5;
}

.contact-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FF6B00;
  margin-right: 24rpx;
}

.contact-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.contact-name {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
  margin-bottom: 4rpx;
}

.contact-phone {
  font-size: 26rpx;
  color: #888;
}

.contact-arrow {
  font-size: 36rpx;
}
