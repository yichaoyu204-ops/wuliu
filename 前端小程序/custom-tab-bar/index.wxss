.bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(96rpx + env(safe-area-inset-bottom));
  z-index: 9999;
}

.bg {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100%;
  background: #fff;
  border-radius: 14rpx 14rpx 0 0;
  box-shadow: 0 -10rpx 28rpx rgba(20, 33, 61, 0.1);
  border-top: 1rpx solid #e7ecf2;
}

.inner {
  position: absolute;
  bottom: env(safe-area-inset-bottom);
  left: 0;
  right: 0;
  height: 96rpx;
}

/* 默认4个tab */
.item {
  position: absolute;
  bottom: 0;
  width: 187.5rpx;
  height: 96rpx;
  transition: opacity 0.16s ease;
}

.item:active {
  opacity: 0.72;
}

/* 默认4个tab：查单/建单/流程/账单 */
.t0 { left: 0; }
.t1 { left: 187.5rpx; }
.t2 { display: none; }
.t3 { left: 375rpx; }
.t4 { left: 562.5rpx; }

/* 管理员5个tab */
.bar.is-admin .item { width: 150rpx; }
.bar.is-admin .t0 { left: 0; }
.bar.is-admin .t1 { left: 150rpx; }
.bar.is-admin .t2 { left: 300rpx; display: block; }
.bar.is-admin .t3 { left: 450rpx; }
.bar.is-admin .t4 { left: 600rpx; }

/* ---- 图标区域 ---- */
.icon {
  position: absolute;
  top: 12rpx;
  width: 32rpx;
  height: 32rpx;
}

/* 默认居中： (187.5 - 32) / 2 = 77.5rpx */
.t0 .icon, .t1 .icon, .t3 .icon, .t4 .icon {
  left: 77.5rpx;
}

/* 管理员居中： (150 - 32) / 2 = 59rpx */
.bar.is-admin .t0 .icon,
.bar.is-admin .t1 .icon,
.bar.is-admin .t2 .icon,
.bar.is-admin .t3 .icon,
.bar.is-admin .t4 .icon {
  left: 59rpx;
}

.badge {
  position: absolute;
  top: -8rpx;
  right: -16rpx;
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  padding: 0 6rpx;
  background: #e53935;
  color: #fff;
  font-size: 18rpx;
  border-radius: 14rpx;
  text-align: center;
  z-index: 10;
}

/* 主页-房子 */
.home-roof {
  position: absolute;
  top: 2rpx;
  left: 8rpx;
  width: 16rpx;
  height: 10rpx;
  background: #ccc;
}

.home-body {
  position: absolute;
  top: 12rpx;
  left: 4rpx;
  width: 24rpx;
  height: 18rpx;
  background: #ccc;
}

/* 建单-加号 */
.plus-h {
  position: absolute;
  top: 14rpx;
  left: 4rpx;
  width: 24rpx;
  height: 4rpx;
  background: #ccc;
}

.plus-v {
  position: absolute;
  top: 4rpx;
  left: 14rpx;
  width: 4rpx;
  height: 24rpx;
  background: #ccc;
}

/* 全部运单-文档+点 */
.doc-line {
  position: absolute;
  left: 4rpx;
  width: 18rpx;
  height: 3rpx;
  background: #ccc;
}
.doc-dot {
  position: absolute;
  top: 22rpx;
  left: 20rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #ccc;
}

/* 流程-双横线+点 */
.flow-line {
  position: absolute;
  left: 4rpx;
  width: 20rpx;
  height: 3rpx;
  background: #ccc;
}
.flow-dot {
  position: absolute;
  width: 5rpx;
  height: 5rpx;
  border-radius: 50%;
  background: #ccc;
}

/* 账单-三横线 */
.line {
  position: absolute;
  left: 4rpx;
  width: 24rpx;
  height: 3rpx;
  background: #ccc;
}

/* 选中变橙色 */
.on { background: #fca311 !important; }

/* ---- 文字 ---- */
.label {
  position: absolute;
  bottom: 16rpx;
  left: 0;
  width: 187.5rpx;
  text-align: center;
  font-size: 21rpx;
  color: #98a2b3;
}

.bar.is-admin .label {
  width: 150rpx;
}

.label.on {
  background: transparent !important;
  color: #14213d;
  font-weight: 600;
}

/* ---- 指示点 ---- */
.dot {
  position: absolute;
  bottom: 7rpx;
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: transparent;
}

/* 默认居中： (187.5 - 6) / 2 = 90.5rpx */
.t0 .dot, .t1 .dot, .t3 .dot, .t4 .dot {
  left: 90.5rpx;
}

/* 管理员居中： (150 - 6) / 2 = 72rpx */
.bar.is-admin .t0 .dot,
.bar.is-admin .t1 .dot,
.bar.is-admin .t2 .dot,
.bar.is-admin .t3 .dot,
.bar.is-admin .t4 .dot {
  left: 72rpx;
}

.dot.on {
  background: #fca311;
}
