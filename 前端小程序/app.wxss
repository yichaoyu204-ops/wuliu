page {
  min-height: 100%;
  background: #f3f5f8;
  color: #1d2733;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, sans-serif;
}

view,
text,
input,
button,
image {
  box-sizing: border-box;
}

button {
  margin: 0;
}

.tap-scale {
  transition: transform 0.16s ease, opacity 0.16s ease;
}

.tap-scale:active {
  transform: scale(0.98);
  opacity: 0.86;
}

.ui-card {
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(213, 219, 228, 0.9);
  box-shadow: 0 10rpx 28rpx rgba(20, 33, 61, 0.06);
}
